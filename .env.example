# ─── Imágenes publicadas en GHCR ─────────────────────────────────────────────
# Actualizá estos valores cuando salga un nuevo build en CI.
# Para que el proxy funcione, el frontend debe haberse compilado con
# VITE_AUTH_API_BASE y VITE_ORDER_API_BASE vacíos.

FRONTEND_IMAGE=ghcr.io/optimizador-de-envios/frontend:sha-d7763cd
USER_SERVICE_IMAGE=ghcr.io/optimizador-de-envios/user-service:sha-90a4163
SHIPMENT_SERVICE_IMAGE=ghcr.io/optimizador-de-envios/shipment-service:sha-e1ba8e1

# ─── Seguridad compartida ────────────────────────────────────────────────────
# Debe coincidir entre user-service y shipment-service.
JWT_SECRET=CHANGE_ME_SHARED_JWT_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRATION_SECONDS=86400

# ─── Bases de datos ──────────────────────────────────────────────────────────
USER_DB_NAME=user_service
USER_DB_USERNAME=user_service
USER_DB_PASSWORD=user_service

SHIPMENT_DB_NAME=shipment_service
SHIPMENT_DB_USERNAME=shipment_service
SHIPMENT_DB_PASSWORD=shipment_service

JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ─── Shipment-Service ────────────────────────────────────────────────────────
# API key de OpenRouteService. Obtené la tuya en:
# https://openrouteservice.org/dev/#/signup
ORS_API_KEY=YOUR_API_KEY_HERE
